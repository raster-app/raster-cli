{
  "name": "@raster-app/cli",
  "version": "0.1.0",
  "description": "Command-line client for the Raster API",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/raster-app/raster-cli"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "raster": "./dist/index.js"
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --banner '#!/usr/bin/env node'",
    "build:binary": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile raster",
    "gen:types": "bun scripts/gen-types.ts",
    "check:types": "tsc --noEmit",
    "check:tarball": "bun scripts/check-tarball.ts",
    "prepack": "bun run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "25.9.2",
    "commander": "15.0.0",
    "openapi-fetch": "0.17.0",
    "openapi-typescript": "7.13.0",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  }
}
